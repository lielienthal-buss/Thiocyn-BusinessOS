# ============================================================
# Business OS — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Project URL: https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Cloudflare Turnstile (CAPTCHA) ───────────────────────────
# https://dash.cloudflare.com → Turnstile → your site → Site Key
# Use "Always passes" key for development: 1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# ── Anthropic (Jarvis AI + Academy Chat) ─────────────────────
# https://console.anthropic.com → API Keys
# SERVER-SIDE ONLY — never prefix with VITE_
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional / Legacy ────────────────────────────────────────
# Not required if ChatBot uses /api/jarvis (current setup)
# VITE_GOOGLE_API_KEY=your-google-api-key
